{
  "name": "relax-game-collection",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev:web": "turbo run dev --filter=@nicetap/web-app",
    "dev:server": "turbo run dev --filter=@nicetap/server",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "vitest run --exclude 'e2e/**'",
    "test:watch": "vitest --exclude 'e2e/**'",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "check:levels": "tsx scripts/check-levels.ts",
    "ci": "pnpm check:levels && pnpm test && pnpm typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.15.0",
    "playwright": "^1.59.1",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
