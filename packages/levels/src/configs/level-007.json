{
  "id": "level-007",
  "chapter": 1,
  "order": 7,
  "title": "按住别放",
  "instruction": "长按按钮过关",
  "tags": ["long-press"],
  "background": { "type": "color", "value": "#e8f5e9" },
  "objects": [
    {
      "id": "hold-btn",
      "type": "button",
      "position": { "x": 0.5, "y": 0.5 },
      "content": "按住我",
      "style": {
        "fontSize": 22,
        "color": "#ffffff",
        "backgroundColor": "#388E3C",
        "borderRadius": 50,
        "padding": 24
      },
      "interactions": [
        { "type": "click", "emits": "btn-tapped" },
        { "type": "long-press", "emits": "btn-held", "duration": 2000 }
      ],
      "enterAnimation": { "type": "bounce-in", "duration": 500 }
    },
    {
      "id": "progress-hint",
      "type": "text",
      "position": { "x": 0.5, "y": 0.7 },
