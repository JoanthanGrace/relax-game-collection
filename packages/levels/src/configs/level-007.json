  "winConditions": [
    { "type": "event-fired", "eventId": "btn-held" }
  ],
  "failConditions": [
    { "type": "event-count", "eventId": "btn-tapped", "count": 10 }
  ],
  "hints": [
    { "level": "weak", "text": "不是点一下哦", "showAfterFailCount": 3 },
    { "level": "medium", "text": "按久一点试试", "showAfterFailCount": 5 },
    { "level": "strong", "text": "按住2秒不放！", "showAfterFailCount": 8, "highlightObjectId": "hold-btn" }
  ],
  "passFeedback": {
    "texts": ["稳如老狗", "按得好！"],
    "animation": "confetti",
    "sfx": "pass-cheerful"
  },
  "failFeedback": {
    "texts": ["太急了", "冷静一下"],
    "animation": "shake",
    "sfx": "fail-buzz"
  }
