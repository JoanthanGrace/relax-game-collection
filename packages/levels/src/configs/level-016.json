{
  "id": "level-016",
  "chapter": 2,
  "order": 6,
  "title": "加载中",
  "instruction": "请等待加载完成",
  "tags": ["fake-button", "drag-reveal"],
  "background": { "type": "color", "value": "#fafafa" },
  "objects": [
    {
      "id": "loading-spinner",
      "type": "button",
      "position": { "x": 0.5, "y": 0.4 },
      "content": "⏳ 加载中...",
      "style": {
        "fontSize": 22,
        "color": "#757575",
        "backgroundColor": "#f5f5f5",
        "borderRadius": 12,
        "padding": 20
      },
      "interactions": [
        {
          "type": "drag",
          "emits": "loading-removed",
          "dragBounds": "none",
          "dragTarget": { "offScreen": true }
        }
      ],
      "behaviors": [
        { "type": "pulse", "params": { "minScale": 0.95, "maxScale": 1.05, "speed": 1500 } }
      ]
    },
    {
      "id": "progress-text",
      "type": "text",
      "position": { "x": 0.5, "y": 0.55 },
      "content": "已加载 67%...",
      "style": { "fontSize": 14, "color": "#9e9e9e" }
    },
    {
      "id": "hidden-btn",
      "type": "button",
      "position": { "x": 0.5, "y": 0.4 },
      "content": "✅ 过关",
      "style": {
        "fontSize": 24,
        "color": "#ffffff",
        "backgroundColor": "#4CAF50",
        "borderRadius": 12,
        "padding": 18
      },
      "visible": false,
      "interactions": [
        { "type": "click", "emits": "hidden-btn-clicked" }
      ],
      "zIndex": -1
    }
  ],
  "reactions": [
    {
      "trigger": "loading-removed",
      "actions": [
        { "type": "show", "objectId": "hidden-btn" },
        { "type": "hide", "objectId": "progress-text" }
      ]
    }
  ],
  "winConditions": [
    { "type": "event-fired", "eventId": "hidden-btn-clicked" }
  ],
  "hints": [
    { "level": "weak", "text": "它真的在加载吗？", "showAfterFailCount": 3 },
    { "level": "medium", "text": "Loading 可能是骗人的", "showAfterFailCount": 5 },
    { "level": "strong", "text": "试试把加载拖走", "showAfterFailCount": 8, "highlightObjectId": "loading-spinner" }
  ],
  "passFeedback": {
    "texts": ["你是不是真等了一会儿？", "永远别等loading"],
    "animation": "confetti",
    "sfx": "pass-cheerful"
  },
  "failFeedback": {
    "texts": ["还在等？", "别信它"],
    "animation": "shake",
    "sfx": "fail-buzz"
  }
}
